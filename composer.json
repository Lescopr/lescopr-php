{
    "name": "lescopr/lescopr-php",
    "description": "Lescopr PHP SDK - Zero-configuration monitoring for PHP applications. Auto-captures logs, errors and metrics from Laravel, Symfony and vanilla PHP projects.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "lescopr", "monitoring", "logging", "error-tracking", "apm",
        "laravel", "symfony", "php", "metrics", "observability",
        "log-management", "debugging", "performance"
    ],
    "homepage": "https://lescopr.com",
    "support": {
        "issues": "https://github.com/Lescopr/lescopr-php/issues",
        "source": "https://github.com/Lescopr/lescopr-php",
        "docs":   "https://docs.lescopr.com"
    },
    "authors": [
        {
            "name":     "SonnaLabs",
            "email":    "support@lescopr.com",
            "homepage": "https://lescopr.com",
            "role":     "Developer"
        }
    ],
    "require": {
        "php":                "^7.4 || ^8.0",
        "ext-json":           "*",
        "symfony/console":    "^4.4 || ^5.0 || ^6.0 || ^7.0",
        "guzzlehttp/guzzle":  "^6.5 || ^7.0"
    },
    "require-dev": {
        "phpunit/phpunit":    "^9.5 || ^10.0 || ^11.0",
        "mockery/mockery":    "^1.4"
    },
    "suggest": {
        "monolog/monolog":  "Enables Monolog handler for Laravel/Symfony (^1.26 || ^2.0 || ^3.0)",
        "ext-pcntl":        "Enables background daemon process (recommended for long-running apps)",
        "ext-posix":        "Required alongside ext-pcntl for daemon support",
        "ext-curl":         "Improves HTTP transport performance (usually bundled with PHP)",
        "ext-openssl":      "Required for HTTPS transport to api.lescopr.com"
    },
    "autoload": {
        "psr-4": {
            "Lescopr\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Lescopr\\Tests\\": "tests/"
        }
    },
    "bin": [
        "bin/lescopr"
    ],
    "config": {
        "optimize-autoloader": true,
        "sort-packages":       true,
        "allow-plugins":       {}
    },
    "scripts": {
        "test":        "vendor/bin/phpunit --testdox",
        "test:ci":     "vendor/bin/phpunit --no-progress",
        "check":       ["@test"],
        "post-install-cmd": "@php -r \"echo 'Lescopr PHP SDK installed. Run: vendor/bin/lescopr status\\n';\""
    },
    "extra": {
        "laravel": {
            "providers": [
                "Lescopr\\Integrations\\Laravel\\LescoprServiceProvider"
            ],
            "aliases": {
                "Lescopr": "Lescopr\\Integrations\\Laravel\\Facades\\LescoprFacade"
            }
        },
        "branch-alias": {
            "dev-main": "0.1.x-dev"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable":     true
}
