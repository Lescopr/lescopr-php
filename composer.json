{
    "name": "lescopr/lescopr-php",
    "description": "Lescopr PHP SDK - Zero-configuration monitoring for PHP applications. Auto-captures logs, errors and metrics from Laravel, Symfony and vanilla PHP projects.",
    "type": "library",
    "license": "MIT",
    "version": "0.1.0",
    "keywords": [
        "lescopr", "monitoring", "logging", "error-tracking", "apm",
        "laravel", "symfony", "php", "metrics", "observability"
    ],
    "homepage": "https://lescopr.com",
    "authors": [
        {
            "name": "SonnaLabs",
            "email": "support@lescopr.com",
            "homepage": "https://lescopr.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "guzzlehttp/guzzle": "^7.5",
        "monolog/monolog": "^2.0|^3.0",
        "symfony/console": "^6.0|^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "mockery/mockery": "^1.5"
    },
    "suggest": {
        "monolog/monolog": "Required for Laravel/Symfony log handler integration (^2.0|^3.0)",
        "ext-pcntl": "Required for daemon background process support",
        "ext-posix": "Required for daemon background process support",
        "ext-grpc": "Optional - enables native gRPC transport instead of HTTP"
    },
    "autoload": {
        "psr-4": {
            "Lescopr\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Lescopr\\Tests\\": "tests/"
        }
    },
    "bin": [
        "bin/lescopr"
    ],
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "extra": {
        "laravel": {
            "providers": [
                "Lescopr\\Integrations\\Laravel\\LescoprServiceProvider"
            ],
            "aliases": {
                "Lescopr": "Lescopr\\Integrations\\Laravel\\Facades\\LescoprFacade"
            }
        },
        "branch-alias": {
            "dev-main": "0.1.x-dev"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
